# signal_bot.py konfigurasyonu
# Tum degerler 2024-07..2026-06 arasi 30 sembol x 1h Binance verisiyle
# dogrulandi (metodoloji ve tam sonuclar: research/REPORT.md).
# Train: 2024-07..2025-12 uzerinde esik secimi, Test: 2026-01..2026-06 (ayi
# rejimi) uzerinde dogrulama.

# ---------------- Sembol evreni ----------------
# SYMBOLS BOS birakilirsa (varsayilan) bot evreni OTOMATIK kurar: USDT spot
# cifti + aktif USDⓈ-M perp'i olan coinler, PERP 24h hacmine gore sirali ilk
# SYMBOL_MAX_COUNT. Evren her UNIVERSE_REFRESH_HOURS saatte bir yenilenir.
# Siralama perp hacmiyle: islem perp'te acilir ve mutlak spot esigi rejime
# gore kirilir (ayida spot hacimler cokuyor). Filtreler NEDEN var: esikler 30
# likit sembolde dogrulandi; dusuk hacimli coinlerde (manipule pump, genis
# spread, kronik negatif funding) edge'ler OLCULMEDI ve yanlis-pozitif orani
# patlar. Filtreleri 0'a cekmek "tum coinler" demektir ama arastirma bunu
# DESTEKLEMIYOR — kendi riskin.
#SYMBOLS=            # doldurursan otomatik mod kapanir (statik liste)
#SYMBOL_AUTO=true
#SYMBOL_MAX_COUNT=120
#SYMBOL_MIN_PERP_VOLUME_M=10   # milyon $/24h perp hacmi tabani
#SYMBOL_MIN_SPOT_VOLUME_M=1    # milyon $/24h spot tabani (veri kalitesi)
#UNIVERSE_REFRESH_HOURS=24

# Tarama araligi (dk). Varsayilan 15: sinyaller 1h bar kapanisinda dogar,
# daha sik tarama sinyal SETINI degistirmez (kenar-tetikleme); kazanc S2'nin
# ve restart-sonrasi yakalamanin hizlanmasi. Bu bir "scalping modu" DEGILDIR
# (15m/5m ufuklarinda edge yok — REPORT.md Ek A/B).
#SCAN_INTERVAL_MINUTES=15

# Bildirim guven esigi: bu kademenin ALTINDAKI sinyaller loglanir ve API'de
# gorunur ama Telegram/email'e GITMEZ. Kademeler: DUSUK < ORTA < YUKSEK <
# COK YUKSEK. Varsayilan ORTA => S2 (DUSUK: test p=0.08 marjinal) sessiz;
# S1/S1+S4/S3 push edilir. Hepsini almak icin: DUSUK
#NOTIFY_MIN_CONFIDENCE=ORTA

# Bir stratejiyi TAMAMEN kapatmak (taranmaz, loglanmaz): orn. DISABLED_STRATEGIES=S2
# Varsayilan bos: S2 sessiz-kayitta kalir ki /performans canli kanit biriktirsin
# ve kaldir/tut karari veriyle verilsin (REPORT §10.2).
#DISABLED_STRATEGIES=

# ---------------- S1: RSI Uyumsuzlugu (SADECE LONG) ----------------
# RSI_OVERSOLD 20 -> 22.5: train taramasinda 22.5 esigi olay sayisini 2.3x
# artirirken edge'i korudu; test (ayi rejimi) 24h edge +0.31 vol birimi,
# p=0.006, kazanma orani %59. Divergence sarti ayni esikte sinyali ~7x
# seyreltip edge'i ~6x yogunlastiriyor (kalsin).
RSI_PERIOD=14
RSI_OVERSOLD=22.5
DIVERGENCE_LOOKBACK=60
DIVERGENCE_GAP=5
S1_COOLDOWN_HOURS=12
# NOT: RSI_OVERBOUGHT kaldirildi. Short (bearish divergence) tarafi
# 70-90 arasi TUM esiklerde negatif edge uretti (kripto'da asiri alim
# donus degil devam isareti); testte de anlamli degildi.

# ---------------- S2: Funding Squeeze (LONG) ----------------
# Esik -0.02 -> -0.03 ve YENI persistence=2 (ustuste 2 settled funding esik
# altinda): tek okuma -0.02 anlamsizdi (72h edge +0.08, p=0.13); -0.03 +
# persistence=2 train 72h edge +0.29 (p<0.001). Test doneminde +0.14
# (p=0.08, marjinal) - sinyal gercek ama ayi rejiminde zayifladi; izlenmeli.
# Sembol-goreli funding z-skoru varyanti denendi ve testte COKTU ->
# mutlak seviye esigi korundu.
FUNDING_SQUEEZE_THRESHOLD_PCT=-0.03
FUNDING_PERSISTENCE=2
S2_COOLDOWN_HOURS=24

# ---------------- S3: Hacim Anomalisi (SADECE yukari-bar, LONG) ----------------
# Ham hacim z'si yerine LOG-hacim z'si: ham z=3.0 ayda sembol basina ~10
# sinyal (spam) ve zayif edge uretiyordu. Log-z=3.0 + sadece yukari bar:
# test 4h edge +0.25 (p<0.001). Asagi-bar (short) tarafi testte negatifti,
# kaldirildi. Esik degeri 3.0 ama artik LOG olcekte (eski ham 3.0 ile
# karsilastirilamaz).
VOLUME_ZSCORE_THRESHOLD=3.0
VOLUME_ZSCORE_WINDOW=168
S3_COOLDOWN_HOURS=12

# ---------------- S4: Confluence etiketi ----------------
# S1 tetiklendiginde son 24h icinde S3 duzeyinde hacim patlamasi varsa
# sinyal STRONG isaretlenir ("hacimli kapitulasyon dibi"): test 24h edge
# +0.38 (p=0.006), 72h kazanma orani %66; hacimsiz S1'in ~2 kati.
CONFLUENCE_LOOKBACK_HOURS=24

# Sinyal kayit dosyasi (JSONL)
#SIGNAL_LOG=signals.log

# Gunluk Telegram ozeti (yasam sinyali) saati, UTC. Kapatmak: -1
#DAILY_SUMMARY_HOUR_UTC=6

# Tek taramada ayrintili push tavani; fazlasi tek toplu mesajda ozetlenir
#MAX_PUSH_PER_SCAN=6

# /performans komutunun olctugu en fazla olgun sinyal sayisi
#PERF_MAX_SIGNALS=60

# Saatlik piyasa arsivi (OI + bazis + fiyat -> market_archive_YYYY-MM.jsonl,
# ~5MB/ay). OI-tabanli gelecek arastirmalarin veri kaynagi (TABLET.md).
#ARCHIVE_MARKET_DATA=true

# ============================ BILDIRIM KANALLARI ============================
# Asagidaki degerleri YEREL calistirirken bu dosyayi .env olarak kopyalayip
# doldur; BULUTTA (Render) ise kod'a degil Render panelindeki "Environment"
# bolumune gir. Anahtar bos birakilirsa o kanal sessizce devre disi kalir
# (bot yine calisir). Degerleri ASLA repoya commit etme (.env .gitignore'da).

# --- Telegram (BotFather'dan bot olustur, @userinfobot'tan chat id al) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Telegram'dan komut dinleme (/start /check /status). Varsayilan acik; yalnizca
# asagidaki izinli chat'lerden gelen komutlara cevap verir. Kapatmak icin: false
#TELEGRAM_COMMANDS=true
# Arkadaslarin da komut verebilsin + otomatik sinyalleri alsin: chat ID'lerini
# virgulle ekle. Arkadasin ID'sini ogrenmesi icin bota /myid yazmasi yeterli.
#TELEGRAM_ALLOWED_CHAT_IDS=11111111,22222222
# Tam acik mod: HERKES komut verebilir (otomatik sinyaller yine sadece
# yukaridaki abonelere gider). Dikkatli kullan.
#TELEGRAM_OPEN=false

# --- Resend email (resend.com > API Keys) ---
# Ucretsiz kalici katman ~3000 email/ay. Kendi dogruladigin alan adin yoksa
# EMAIL_FROM'u varsayilan sandbox adresinde birak; o durumda email SADECE
# Resend hesabina kayitli/dogrulanmis kendi adresine gider.
RESEND_API_KEY=
NOTIFICATION_EMAIL=
#EMAIL_FROM=Signal Bot <onboarding@resend.dev>

# Mobil endpoint tamponundaki maksimum sinyal sayisi (server.py)
#RECENT_MAXLEN=100
